{
  "hooks": [
    {
      "matcher": {
        "event": "PreToolUse",
        "tool_name": "Bash"
      },
      "hooks": [
        {
          "type": "command",
          "command": "node \"$PLUGIN_DIR/scripts/hooks/pre-bash-openclaw-check.js\"",
          "timeout": 5000
        }
      ]
    },
    {
      "matcher": {
        "event": "SessionStart"
      },
      "hooks": [
        {
          "type": "command",
          "command": "node \"$PLUGIN_DIR/scripts/hooks/session-start-docs-check.js\"",
          "timeout": 5000
        }
      ]
    },
    {
      "matcher": {
        "event": "PostToolUse",
        "tool_name": "Bash"
      },
      "hooks": [
        {
          "type": "command",
          "command": "node \"$PLUGIN_DIR/scripts/hooks/post-bash-config-validator.js\"",
          "timeout": 5000
        }
      ]
    }
  ]
}
